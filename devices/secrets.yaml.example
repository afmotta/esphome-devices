# WiFi credentials (all devices; T-Connect Pro boards require these even when
# built with enable_ethernet: true — see deferred-work note from ADR-0014 P4)
wifi_ssid: "your_ssid"
wifi_password: "your_password"
# Lighting controller's HA API encryption key (devices/light-controller.yaml).
# Each ESPHome device has its own API encryption key. openssl rand -base64 32
api_encryption_key: "your_base64_32_byte_key"
# CAN bus health monitor's HA API encryption key (devices/health-monitor.yaml,
# ADR-0015). Its own key, distinct from the gateway's. openssl rand -base64 32
health_monitor_encryption_key: "your_base64_32_byte_key"
# Climate-control / sensor devices' HA API encryption key, referenced by the
# devices/locals/ and devices/remotes/ wrappers (climate-control, room-sensor,
# wall-sensor). Generate with: openssl rand -base64 32
encryption_key: "your_base64_32_byte_key"
# OTA authentication (ADR-0010 §5). Generate with: openssl rand -base64 32
ota_password: "your_ota_password"
# GitHub-pull deployment (devices/remotes/ wrappers only): the repo/user the
# remote config is fetched from, and a PAT with read access to it.
github_username: "your_github_username"
github_pat: "ghp_your_personal_access_token"
